{
  "name": "aparecida-erp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:test": "dotenv -e .env.test -- next dev",
    "postinstall": "prisma generate",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:reset:prod": "node scripts/reset-prod-db.mjs",
    "db:reset:test": "dotenv -e .env.test -- node scripts/reset-test-db.mjs",
    "db:seed:test": "dotenv -e .env.test -- node scripts/seed-test-db.mjs",
    "db:fresh:test": "dotenv -e .env.test -- npx prisma migrate deploy && dotenv -e .env.test -- node scripts/reset-test-db.mjs && dotenv -e .env.test -- node scripts/seed-test-db.mjs",
    "test:e2e": "dotenv -e .env.test -- npx prisma migrate deploy && dotenv -e .env.test -- playwright test",
    "test:e2e:ui": "dotenv -e .env.test -- npx prisma migrate deploy && dotenv -e .env.test -- playwright test --ui",
    "test:e2e:reset": "dotenv -e .env.test -- npx prisma migrate deploy && dotenv -e .env.test -- node scripts/reset-test-db.mjs && dotenv -e .env.test -- node scripts/seed-test-db.mjs && dotenv -e .env.test -- playwright test"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
