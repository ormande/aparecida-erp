# ===========================
# APARECIDA ERP - Variáveis de Ambiente
# ===========================

# DATABASE (Railway PostgreSQL)
# Use a URL pública para rodar migrations localmente
DATABASE_URL="postgresql://user:password@host:port/database?connection_limit=5&pool_timeout=10"
DIRECT_URL="postgresql://user:password@host:port/database"

# NEXTAUTH
# Gere em: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=""
NEXTAUTH_URL=""

# EMPRESA
NEXT_PUBLIC_APP_NAME="Aparecida ERP"

# UPSTASH Redis
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
CRON_SECRET=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# --- Banco de TESTE (arquivo separado: .env.test) ---
# Nunca copie ALLOW_DB_* para o .env de producao.
# Os comandos npm db:*:test e dev:test carregam apenas .env.test (nao o .env).
# DATABASE_URL="postgresql://...@localhost:5432/aparecida_test"
# ALLOW_DB_RESET=true
# ALLOW_DB_SEED=true
# TEST_OWNER_EMAIL="teste@exemplo.local"
# TEST_OWNER_PASSWORD="123456"
