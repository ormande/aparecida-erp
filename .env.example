# ===========================
# APARECIDA ERP — Variáveis de Ambiente
# ===========================

# DATABASE (Railway PostgreSQL)
# Obtenha no painel do Railway após criar um serviço PostgreSQL
DATABASE_URL="postgresql://user:password@host:port/database"

# NEXTAUTH
# Gere em: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="seu-secret-aqui"
NEXTAUTH_URL="http://localhost:3000"

# GOOGLE OAUTH (para login com Google)
# 1. Acesse https://console.cloud.google.com
# 2. Crie um projeto
# 3. Ative a API "Google+ API" ou "Google Identity"
# 4. Em "Credenciais" > "Criar credenciais" > "ID do cliente OAuth"
# 5. Adicione http://localhost:3000/api/auth/callback/google como URI autorizado
GOOGLE_CLIENT_ID="seu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu-client-secret"

# EMPRESA (configuração inicial)
NEXT_PUBLIC_APP_NAME="Aparecida ERP"
NEXT_PUBLIC_EMPRESA_NOME="Borracharia Nossa Senhora Aparecida"
